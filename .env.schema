# example env variable injected by `varlock init` ⚠️ DELETE THIS ITEM! ⚠️
# @required @sensitive @example="example value"
EXAMPLE_ITEM="delete me!"

# Clerk Authentication
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# Convex Backend
# @type=url
EXPO_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# OpenAI (for Whisper transcription)
EXPO_PUBLIC_OPENAI_API_KEY=sk-xxx

# Amplitude Analytics
EXPO_PUBLIC_AMPLITUDE_API_KEY=xxx

# ElevenLabs TTS (Neural text-to-speech for humanlike voice playback)
EXPO_PUBLIC_ELEVENLABS_API_KEY=

# ElevenLabs server-side key (used by Convex actions to generate community TTS cache)
# @sensitive
ELEVENLABS_SERVER_API_KEY=

